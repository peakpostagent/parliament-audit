coverage/

# Database
*.db
*.sqlite

# TypeScript build info
*.tsbuildinfo
.browser-profile/

# Umami deploy secrets
.umami-creds.json

# Social-brief state (per-machine; tracks what URIs we've replied to)
content/social-briefs/.state.json

# X mirror per-machine state
content/social-briefs/.x-mirror-state.json

# X mirror per-post-verification failure audit log (gitignored — local-only
# audit trail. NOT a substitute for re-queueing; failed entries stay in
# x-mirror-queue.json and re-attempt on the next run).
content/social-briefs/.x-mirror-failures.json

# Mastodon mirror per-machine state
content/social-briefs/.mastodon-state.json

# Analytics snapshots — daily JSON dump + follower-growth ledger.
# Per-machine, contains live numbers from the social APIs at snapshot
# time. We don't commit these because (a) they update every cron tick
# and would bloat the diff history, and (b) anyone with read access to
# the repo could correlate timing with our follower-count fluctuations.
content/analytics/.followers-ledger.json
content/analytics/snapshot-*.json
