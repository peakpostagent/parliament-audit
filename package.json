{
  "name": "parliament-audit",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "npm run migrate --workspace=@parliament-audit/db",
    "db:push": "npm run push --workspace=@parliament-audit/db",
    "db:seed": "npm run seed --workspace=@parliament-audit/db"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "twitter-api-v2": "^1.29.0"
  }
}
